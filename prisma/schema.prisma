generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

// ─────────────────────────────────────────
// MODELOS OBRIGATÓRIOS DO NEXTAUTH ADAPTER
// ─────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────
// MODELO USER — NEXTAUTH + NEGÓCIO
// ─────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // null para usuários que logam via Google

  // Campos de negócio
  role          String    @default("USER") // USER | COMPANY | ADMIN
  offChainLeafs Float     @default(0)
  stellarAddress String?  // preenchido quando o usuário conecta carteira (opcional)
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relações NextAuth
  accounts      Account[]
  sessions      Session[]

  // Relações de negócio
  company       Company?          // apenas se role = COMPANY
  stamps        Stamp[]
  claimCodes    ClaimCode[]
  scanLogs      ScanLog[]
  redemptions   CampaignRedemption[]
}

// ─────────────────────────────────────────
// DOMÍNIO DE NEGÓCIO
// ─────────────────────────────────────────

model Company {
  id          String   @id @default(cuid())
  userId      String   @unique
  legalName   String
  tradeName   String
  cnpj        String?  @unique
  category    String   // ESCOLA | HOTEL | CAFE | COMERCIO | ONG | OUTRO
  city        String
  state       String
  description String?
  logoUrl     String?
  stampImageUrl String?
  monthlyQrSecret String
  rewardAmount Float   @default(10)
  isActive    Boolean  @default(false) // Admin ativa após verificação
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stamps      Stamp[]
  scanLogs    ScanLog[]
  campaigns   Campaign[]
}

model Stamp {
  id              String          @id @default(cuid())
  userId          String
  companyId       String
  partnerName     String
  partnerCategory String
  stampImageUrl   String?
  scannedAt       DateTime        @default(now())

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])
}

model ScanLog {
  id          String   @id @default(cuid())
  userId      String
  companyId   String
  ipAddress   String?
  deviceHash  String?
  latitude    Float?
  longitude   Float?
  scannedAt   DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@index([userId, companyId, scannedAt])
}

model ClaimCode {
  id         String      @id @default(cuid())
  code       String      @unique @default(cuid())
  userId     String
  amount     Float
  status     String      @default("ACTIVE") // ACTIVE | REDEEMED | EXPIRED
  txHash     String?
  createdAt  DateTime    @default(now())
  redeemedAt DateTime?

  user User @relation(fields: [userId], references: [id])
}

model Campaign {
  id           String    @id @default(cuid())
  title        String
  description  String
  leafReward   Float                       // Leafs que o usuário GANHA
  imageUrl     String?
  qrSecret     String    @unique           // Segredo para gerar o QR Code
  codeText     String?   @unique           // Código de texto alternativo (ex: VISITA25)
  maxUses      Int?                        // null = ilimitado
  currentUses  Int       @default(0)
  expiresAt    DateTime?
  isActive     Boolean   @default(true)
  companyId    String?                     // null = campanha global criada pelo Admin
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company     Company?            @relation(fields: [companyId], references: [id], onDelete: SetNull)
  redemptions CampaignRedemption[]
}

model CampaignRedemption {
  id         String   @id @default(cuid())
  userId     String
  campaignId String
  leafsEarned Float
  redeemedAt DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}
